function int add(int a, int b):
    return a + b

function int main():
    int count = 0  // contador
    bool active = true

    /* bloque
       multilinea */
    if count < 10:
        count = count + 1
    else:
        count = 0

    for (int i = 0; i < 10; i = i + 1):
        count = count + i

    while count > 0:
        count = count - 1

    return count
